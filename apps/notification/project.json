{
  "name": "notification",
  "sourceRoot": "apps/notification/src",
  "projectType": "application",
  "tags": ["type:app", "scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build notification --webpackPath ./apps/notification/webpack.config.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "export NODE_ENV=development && nest start --watch notification --webpackPath ./apps/notification/webpack.config.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --testPathPattern=apps/notification",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"apps/notification/src/**/*.ts\" --fix",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
