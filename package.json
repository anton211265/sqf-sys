  "scripts": {
    "build": "nest build ${npm_config_project} --webpackPath ./apps/${npm_config_project}/webpack.config.js",
    "build:web": "vite build apps/web",
    "serve:web": "vite apps/web",
    "build:web-next": "vite build apps/web-next",
    "serve:web-next": "vite apps/web-next",
    "format": "prettier --write \"apps/**/*.ts\" \"apps/**/*.tsx\" \"libs/**/*.ts\"",
    "start": "export NODE_ENV=development && nest start ${npm_config_project} --webpackPath ./apps/${npm_config_project}/webpack.config.js",
    "start:dev": "export NODE_ENV=development && nest start --watch ${npm_config_project} --webpackPath ./apps/${npm_config_project}/webpack.config.js",
    "start:debug": "export NODE_ENV=development && nest start --debug --watch ${npm_config_project} --webpackPath ./apps/${npm_config_project}/webpack.config.js",
    "start:prod": "node dist/apps/trade-directory/main",
    "script": "ts-node -r tsconfig-paths/register",
    "script:dev": "nodemon -r tsconfig-paths/register",
    "script:build": "export ISSCRIPT=1 && webpack --config ./apps/${npm_config_project}/webpack.config.js",
    "ts-typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "export NODE_ENV=development && npm run ts-typeorm migration:generate -- -d ./apps/${npm_config_project}/typeorm.config.js ./apps/${npm_config_project}/migrations/${npm_config_migration_name}",
    "migration:run": "export NODE_ENV=development && npm run ts-typeorm migration:run -- -d ./apps/${npm_config_project}/typeorm.config.js",
    "migration:revert": "export NODE_ENV=development && npm run ts-typeorm migration:revert -- -d ./apps/${npm_config_project}/typeorm.config.js",
    "migration:build": "npx tsc ./apps/${npm_config_project}/migrations/*.ts --outDir ./dist/apps/${npm_config_project}/migrations",
    "proto:generate": "find libs/common/src/apps -type f -name \"*.proto\" -exec sh -c 'protoc --proto_path=./libs/common/src/apps --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=nestJs=true --ts_proto_opt=useDate=true --ts_proto_opt=stringEnums=true --ts_proto_opt=removeEnumPrefix=true --ts_proto_out=./libs/common/src/apps {}' \\;",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/trade-directory/test/jest-e2e.json",
    "sonar": "sonar-scanner -Dsonar.host.url=http://10.0.26.178:9000 -Dsonar.login=sqp_1727491064d032e00f29c57db1e12e364422d38f -Dsonar.projectName=nh-dev-app -Dsonar.projectKey=nh-dev-app"
  },
