{
  "name": "common",
  "sourceRoot": "libs/common/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/common/tsconfig.lib.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"libs/common/src/**/*.ts\" --fix",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
