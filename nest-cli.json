{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/trade-directory/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/trade-directory/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/trade-directory",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "trade-directory": {
      "type": "application",
      "root": "apps/trade-directory",
      "entryFile": "main",
      "sourceRoot": "apps/trade-directory/src",
      "compilerOptions": {
        "tsConfigPath": "apps/trade-directory/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/common/src/apps/**/*.proto",
            "outDir": "dist/apps/trade-directory",
            "watchAssets": true
          }
        ]
      }
    },
    "document-management": {
      "type": "application",
      "root": "apps/document-management",
      "entryFile": "main",
      "sourceRoot": "apps/document-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/document-management/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/common/src/apps/**/*.proto",
            "outDir": "dist/apps/document-management",
            "watchAssets": true
          }
        ]
      }
    },
    "customer-relationship-management": {
      "type": "application",
      "root": "apps/customer-relationship-management",
      "entryFile": "main",
      "sourceRoot": "apps/customer-relationship-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/customer-relationship-management/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/common/src/apps/**/*.proto",
            "outDir": "dist/apps/customer-relationship-management",
            "watchAssets": true
          }
        ]
      }
    },
    "risk-operation": {
      "type": "application",
      "root": "apps/risk-operation",
      "entryFile": "main",
      "sourceRoot": "apps/risk-operation/src",
      "compilerOptions": {
        "tsConfigPath": "apps/risk-operation/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/common/src/apps/**/*.proto",
            "outDir": "dist/apps/risk-operation",
            "watchAssets": true
          }
        ]
      }
    },
    "notification": {
      "type": "application",
      "root": "apps/notification",
      "entryFile": "main",
      "sourceRoot": "apps/notification/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/common/src/apps/**/*.proto",
            "outDir": "dist/apps/notification",
            "watchAssets": true
          },
          {
            "include": "../templates/**/*.pug",
            "outDir": "dist/apps/notification/templates",
            "watchAssets": true
          }
        ]
      }
    }
  }
}
